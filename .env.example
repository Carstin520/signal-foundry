# Copy this file to .env and fill local secrets. Never commit .env.

# X API OAuth 2.0 Bearer Token from the X Developer Console.
# Required for:
#   python3 -m quant_sol.signals sync-social
#   python3 -m quant_sol.signals sync-accounts
#   python3 -m quant_sol.signals sync-follow-graph
X_BEARER_TOKEN=

# Telegram Bot API credentials. Optional until you want live alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
